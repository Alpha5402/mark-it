{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mark It Desktop",
  "version": "0.1.0",
  "identifier": "studio.mark-it.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mark It Desktop",
        "width": 1280,
        "height": 820,
        "minWidth": 1060,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
