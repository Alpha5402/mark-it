{
  "name": "@mark-it/core",
  "version": "1.0.0",
  "description": "Core markdown engine parser and renderer",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./style.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean"
  },
  "peerDependencies": {
    "prismjs": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/prismjs": "^1.26.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "escape": "^0.0.1"
  }
}
